+.scrollbar-thick::-webkit-scrollbar {
+  width: 14px;
+}
+
+.scrollbar-thick::-webkit-scrollbar-track {
+  background: #e5e7eb;
+  border-radius: 0;
+}
+
+.scrollbar-thick::-webkit-scrollbar-thumb {
+  background: #9ca3af;
+  border-radius: 0;
+}
+
+.scrollbar-thick::-webkit-scrollbar-thumb:hover {
