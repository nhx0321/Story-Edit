+                isActive ? 'bg-gray-700 text-gray-200' : 'bg-amber-100 text-amber-700'
+              }`}>{pendingCount}</span>
+            )}
+            {isDeletedTab && showBadge && (
+              <span className={`text-xs px-1 py-0.5 rounded-full ${
+                isActive ? 'bg-gray-700 text-gray-200' : 'bg-red-100 text-red-700'
+              }`}>{deletedCount}</span>
+            )}
+          </button>
