+
+/* 琥珀色边框闪烁3次（新项目大纲编辑引导） */
+@keyframes amber-flash {
+  0%, 100% { border-color: rgb(229 119 42 / 0); }
+  10%, 30%, 50% { border-color: rgb(245 158 11 / 0.8); box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2); }
+  20%, 40% { border-color: rgb(229 119 42 / 0); box-shadow: none; }
+  60% { border-color: rgb(245 158 11 / 0.8); box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2); }
+  70%, 100% { border-color: rgb(229 119 42 / 0); box-shadow: none; }
+}
+
+.animate-amber-flash {
+  animation: amber-flash 3s ease-in-out 1 forwards;
+}
+
