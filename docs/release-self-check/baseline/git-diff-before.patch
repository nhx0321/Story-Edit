+                      </>
+                    )}
+                    <button onClick={() => handleDelete(t.id, t.title)}
+                      className="px-4 py-1.5 text-sm text-red-500 hover:text-red-700 transition">
+                      删除
+                    </button>
+                  </div>
+                </>
+              )}
+            </div>
+          ))}
+        </div>
+      )}
+    </>
+  );
