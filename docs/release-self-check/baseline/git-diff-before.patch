+export async function generateTexts(input: {
+  species: string;
+  variant: string;
+  textType: 'user-trigger' | 'idle-phase';
+  requirement: string;
+  count: number;
+  levels: number[];
+}) {
+  const { species, variant, textType, requirement, count, levels } = input;
+
+  // Call AI to generate sprite text entries
+  const config = await getUserAIConfig();
+  if (!config) {
+    throw new Error('未找到可用的 AI 配置，请先在 AI 设置中配置 API 端点');
+  }
+
+  const systemPrompt = `你是一个精灵交互文本生成助手。你的任务是根据管理员的要求，为精灵生成多条交互文本（触发条件 + 回复文本）。
+
+要求：
+1. 回复必须活泼可爱，符合精灵的陪伴者角色
+2. 每条文本应当独特，不重复
+3. 触发条件要具体，回复文本要简短（不超过50字）
+4. 语气要可爱、温暖、有亲和力
+
+请以 JSON 数组格式返回，每个元素包含 triggerCondition 和 responseText 两个字段。
+返回格式示例：
+[{"triggerCondition": "xxx", "responseText": "yyy"}, {"triggerCondition": "xxx2", "responseText": "yyy2"}]`;
+
+  const textTypeLabel = textType === 'user-trigger' ? '用户触发' : '待机阶段';
+  const userPrompt = `请为精灵（${species}/${variant}）生成 ${count} 条交互文本。
+
+交互类型：${textTypeLabel}
+管理员要求：${requirement}
+${levels.length > 0 ? `适用等级：${levels.map(l => `L${l}`).join('、')}` : '适用等级：全部等级（通用模板）'}
+
+请只返回 JSON 数组，不要其他内容。`;
+
+  const messages = [
+    { role: 'system' as const, content: systemPrompt },
+    { role: 'user' as const, content: userPrompt },
+  ];
+
+  const result = await callAI(config, messages, 2000);
+  const generated = parseGeneratedTexts(result.content);
+
+  // Save generated entries to database
+  const created: { id: string; triggerCondition: string; responseText: string; level: number }[] = [];
+  const targetLevels = levels.length > 0 ? levels : [-1]; // default to generic template
+
+  for (const item of generated) {
+    const level = targetLevels[0]; // For first batch, create at generic level
+    const [entry] = await db.insert(spriteTextEntries).values({
+      species,
+      variant,
+      level,
+      textType,
+      triggerCondition: item.triggerCondition,
+      responseText: item.responseText,
+      status: 'draft',
+    }).returning();
+    if (entry) {
+      created.push({ id: entry.id, triggerCondition: item.triggerCondition, responseText: item.responseText, level });
+    }
+  }
+
+  return { created, count: created.length };
+}
+
+async function getUserAIConfig() {
+  const [config] = await db.select({
+    id: aiConfigs.id,
+    provider: aiConfigs.provider,
+    baseUrl: aiConfigs.baseUrl,
+    defaultModel: aiConfigs.defaultModel,
+    apiKey: aiConfigs.apiKey,
+  }).from(aiConfigs).limit(1);
+  return config || null;
+}
+
+async function callAI(config: {
+  id: string;
+  provider: string;
+  baseUrl: string | null;
+  defaultModel: string | null;
+  apiKey: string;
+}, messages: AIMessage[], maxTokens?: number) {
+  const apiKey = decryptApiKey(config.apiKey);
+  const adapter = createAdapter(config.provider, {
+    apiKey,
+    baseUrl: config.baseUrl || undefined,
+    defaultModel: config.defaultModel || undefined,
+  });
+  const result = await adapter.chat(messages, {
+    maxTokens: maxTokens || 1000,
+    temperature: 0.8,
+  });
+  return { content: result.content };
+}
+
+function parseGeneratedTexts(content: string): { triggerCondition: string; responseText: string }[] {
+  // Try to extract JSON array from the response
+  const jsonMatch = content.match(/\[[\s\S]*\]/);
+  if (!jsonMatch) return [];
+
+  try {
+    const parsed = JSON.parse(jsonMatch[0]);
+    if (Array.isArray(parsed)) {
+      return parsed
+        .filter((item: any) => item.triggerCondition && item.responseText)
+        .map((item: any) => ({
+          triggerCondition: item.triggerCondition,
+          responseText: item.responseText,
+        }));
+    }
+  } catch {
+    // If JSON parse fails, return empty - let the admin retry
+  }
+  return [];
+}
