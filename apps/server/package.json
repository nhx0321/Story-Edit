{
  "name": "@story-edit/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.mjs",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.1",
    "@fastify/websocket": "^11.0.2",
    "@trpc/server": "^10.45.2",
    "drizzle-orm": "^0.44.2",
    "postgres": "^3.4.7",
    "@story-edit/shared": "workspace:*",
    "@story-edit/ai-adapters": "workspace:*",
    "zod": "^3.24.4",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^3.0.2",
    "ioredis": "^5.6.1",
    "bullmq": "^5.52.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "tsup": "^8.4.0",
    "drizzle-kit": "^0.31.1"
  }
}
