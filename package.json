{
    "name": "story-edit",
    "version": "0.1.0",
    "private": true,
    "description": "AI辅助小说创作平台",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "clean": "turbo clean",
        "db:migrate": "pnpm --filter @story-edit/server db:migrate",
        "db:generate": "pnpm --filter @story-edit/server db:generate",
        "db:studio": "pnpm --filter @story-edit/server db:studio",
        "db:verify:fresh": "pnpm --filter @story-edit/server db:verify:fresh",
        "db:verify:upgrade": "pnpm --filter @story-edit/server db:verify:upgrade"
    },
    "keywords": [],
    "author": "",
    "license": "UNLICENSED",
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "msgpackr-extract"
        ],
        "overrides": {
            "glob": ">=10.5.0",
            "postcss": ">=8.5.10",
            "uuid": ">=14.0.0",
            "esbuild": ">=0.25.0"
        },
        "ignoredBuiltDependencies": [
            "sharp",
            "unrs-resolver"
        ]
    },
    "devDependencies": {
        "turbo": "^2.9.5"
    },
    "dependencies": {
        "pg": "^8.20.0"
    }
}