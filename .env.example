# 环境变量模板 — 复制为 .env 后填写

# PostgreSQL
DATABASE_URL=postgresql://story_edit:story_edit_dev@localhost:5432/story_edit

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production

# AI Key 加密密钥
AI_KEY_ENCRYPTION_SECRET=change-me-in-production

# 服务端口
SERVER_PORT=3001
WEB_PORT=3000

# Next.js 代理 / SSR 访问后端地址
SERVER_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# 浏览器直连后端地址（生产环境请改成公网域名或 IP）
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
